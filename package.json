{
  "name": "diesel-ctrl-pos",
  "version": "1.0.0",
  "description": "Sistema de Punto de Venta para Repuestos Diesel",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watchAll",
    "build:css": "npx tailwindcss -i ./public/styles/tailwind.css -o ./public/styles.css --minify",
    "scss": "sass --watch public/styles/scss:public/styles",
    "build:scss": "sass public/styles/scss:public/styles --no-source-map"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.0.0",
    "cookie-parser": "^1.4.6",
    "csurf": "^1.11.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-sslify": "^1.2.0",
    "express-validator": "^7.3.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "speakeasy": "^2.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "postcss": "^8.5.6",
    "sass": "^1.97.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.3.5"
  }
}
